# PostgreSQL 连接配置
#
# 如果你知道 PostgreSQL 的 postgres 用户密码，请填写下方
# 如果不知道，请运行：./scripts/reset_postgres_password.sh

# PostgreSQL 连接信息
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=llm_wiki
POSTGRES_USER=llm_wiki
POSTGRES_PASSWORD=llm_wiki_dev

# PostgreSQL 超级用户（用于初始化）
# 如果你记得 postgres 密码，请取消注释并填写
# POSTGRES_ADMIN_PASSWORD=your_postgres_password

# 说明：
# 1. 如果你知道 postgres 密码，填写 POSTGRES_ADMIN_PASSWORD
# 2. 然后运行：./scripts/setup_database.sh
# 3. 如果不知道密码，运行：./scripts/reset_postgres_password.sh