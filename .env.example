# LLM Wiki Docker Compose 环境配置

# PostgreSQL
POSTGRES_DB=llm_wiki
POSTGRES_USER=llm_wiki
POSTGRES_PASSWORD=llm_wiki_dev
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# LLM Wiki
LLM_WIKI_STORAGE_MODE=db
LLM_WIKI_STORAGE_TYPE=postgres
LLM_WIKI_HOST=0.0.0.0
LLM_WIKI_PORT=8000
LLM_WIKI_POOL_SIZE=10

# Casdoor SSO（默认禁用，启用需设置 SSO_ENABLED=true）
SSO_ENABLED=false
CASDOOR_PORT=8001
CASDOOR_ENDPOINT=http://casdoor:8000
CASDOOR_CLIENT_ID=
CASDOOR_CLIENT_SECRET=
CASDOOR_ORGANIZATION=llm-wiki
CASDOOR_APPLICATION=llm-wiki-app
CASDOOR_CERTIFICATE=
CASDOOR_REDIRECT_URI=http://localhost:8000/api/auth/sso/callback
